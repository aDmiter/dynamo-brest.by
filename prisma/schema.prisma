generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model admin {
  id        String   @id @default(cuid())
  email     String   @unique(map: "Admin_email_key")
  password  String
  name      String
  role      String   @default("editor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model banner {
  id            String    @id @default(cuid())
  title         String
  imageUrl      String
  linkUrl       String
  clicks        Int       @default(0)
  views         Int       @default(0)
  isActive      Boolean   @default(true)
  position      String    @default("home")
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  backgroundUrl String?
}

model match {
  id              String       @id @default(cuid())
  cometId         String?      @unique(map: "Match_cometId_key")
  teamId          String
  homeTeamId      Int?
  awayTeamId      Int?
  homeTeam        String
  awayTeam        String
  homeLogoUrl     String?
  awayLogoUrl     String?
  homeScore       Int?
  awayScore       Int?
  matchDate       DateTime
  stadium         String?
  facilityId      Int?
  facility        Facility?    @relation(fields: [facilityId], references: [cometId])
  tournament      String?
  tournamentId    String?
  round           String?
  status          String       @default("scheduled")
  isHome          Boolean      @default(true)
  matchType       String?
  gender          String?
  attendance      Int?
  ticketUrl       String?
  customFields    Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  team            team         @relation(fields: [teamId], references: [id], map: "Match_teamId_fkey")
  homeOpponent    OpponentTeam? @relation("HomeMatches", fields: [homeTeamId], references: [cometId])
  awayOpponent    OpponentTeam? @relation("AwayMatches", fields: [awayTeamId], references: [cometId])

  @@index([teamId], map: "Match_teamId_fkey")
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model OpponentTeam {
  id        String   @id @default(cuid())
  cometId   Int?     @unique
  name      String
  shortName String?
  logoUrl   String?
  city      String?
  country   String?
  gender    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  homeMatches match[] @relation("HomeMatches")
  awayMatches match[] @relation("AwayMatches")
}

model Facility {
  id        String   @id @default(cuid())
  cometId   Int      @unique
  name      String
  shortName String?
  address   String?
  city      String?
  region    String?
  country   String?
  type      String?
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  matches   match[]
}

model news {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique(map: "News_slug_key")
  content     String   @db.Text
  excerpt     String   @db.Text
  imageUrl    String?
  isFeatured  Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    String   @default("general")
  isPublished Boolean  @default(true)
}

model order {
  id            String      @id @default(cuid())
  customerName  String
  customerEmail String?
  customerPhone String
  address       String?
  comment       String?     @db.Text
  status        String      @default("new")
  total         Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderNumber   String?     @unique
  trackingCode  String?
  deliveryPrice Decimal?    @db.Decimal(10, 2)
  orderitem     orderitem[]
}

model orderitem {
  id            String  @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  price         Decimal @db.Decimal(10, 2)
  size          String?
  customization String? @db.Text
  order         order   @relation(fields: [orderId], references: [id], map: "OrderItem_orderId_fkey")
  product       product @relation(fields: [productId], references: [id], map: "OrderItem_productId_fkey")

  @@index([orderId], map: "OrderItem_orderId_fkey")
  @@index([productId], map: "OrderItem_productId_fkey")
}

model player {
  id                String       @id @default(cuid())
  cometId           String?      @unique(map: "Player_cometId_key")
  firstName         String
  lastName          String
  middleName        String?
  shortName         String?
  number            Int?
  position          String?
  birthDate         DateTime?
  nationality       String?
  country           String?
  city              String?
  gender            String?
  level             String?
  height            Int?
  weight            Int?
  photoUrl          String?
  bio               String?      @db.Text
  isActive          Boolean      @default(true)
  isPublished       Boolean      @default(true)
  isManuallyCreated Boolean      @default(false)
  order             Int          @default(0)
  customFields      Json?
  gallery           String?      @db.LongText
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  playerTeams       PlayerTeam[]
  slug              String?      @unique
}

model PlayerTeam {
  playerId String
  teamId   String
  player   player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team     team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([playerId, teamId])
}

model coach {
  id                String       @id @default(cuid())
  cometId           String?      @unique
  firstName         String
  lastName          String
  middleName        String?
  shortName         String?
  position          String?
  birthDate         DateTime?
  nationality       String?
  country           String?
  city              String?
  gender            String?
  photoUrl          String?
  bio               String?      @db.Text
  gallery           String?      @db.LongText
  isActive          Boolean      @default(true)
  isPublished       Boolean      @default(true)
  isManuallyCreated Boolean      @default(false)
  order             Int          @default(0)
  type              String       @default("coach")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  coachTeams        CoachTeam[]
}

model CoachTeam {
  coachId String
  teamId  String
  coach   coach @relation(fields: [coachId], references: [id], onDelete: Cascade)
  team    team  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([coachId, teamId])
}

model product {
  id                String            @id @default(cuid())
  categoryId        String
  name              String
  slug              String            @unique(map: "Product_slug_key")
  description       String            @db.Text
  price             Decimal           @db.Decimal(10, 2)
  oldPrice          Decimal?          @db.Decimal(10, 2)
  inStock           Boolean           @default(true)
  isFeatured        Boolean           @default(false)
  images            String?           @db.Text
  sizes             String?           @db.Text
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  article           String?           @unique(map: "Product_article_key")
  composition       String?           @db.Text
  quantity          Int               @default(0)
  hasCustomization  Boolean           @default(false)
  useSizes          Boolean           @default(false)
  totalSold         Int               @default(0)
  orderitem         orderitem[]
  productsize       ProductSize[]
  productcategory   productcategory   @relation(fields: [categoryId], references: [id], map: "Product_categoryId_fkey")

  @@index([categoryId], map: "Product_categoryId_fkey")
}

model productcategory {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique(map: "ProductCategory_slug_key")
  imageUrl  String?
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  product   product[]
}

model sponsor {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  linkUrl   String?
  type      String   @default("general")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model standings {
  id           String   @id @default(cuid())
  tournamentId String
  teamName     String
  teamLogoUrl  String?
  position     Int
  played       Int      @default(0)
  won          Int      @default(0)
  drawn        Int      @default(0)
  lost         Int      @default(0)
  goalsFor     Int      @default(0)
  goalsAgainst Int      @default(0)
  points       Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model team {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique(map: "Team_slug_key")
  cometId     String?      @unique(map: "Team_cometId_key")
  isActive    Boolean      @default(true)
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  match       match[]
  playerTeams PlayerTeam[]
  coachTeams  CoachTeam[]
}

model title {
  id        String   @id @default(cuid())
  name      String
  year      Int
  imageUrl  String?
  type      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model translation {
  id        String   @id @default(cuid())
  key       String
  locale    String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, locale], map: "Translation_key_locale_key")
}

model Country {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  price     Decimal? @db.Decimal(10, 2)
  isActive  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductSize {
  id        String   @id @default(cuid())
  productId String
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, size])
}

model Customization {
  id        String   @id @default(cuid())
  name      String
  type      String
  imageUrl  String?
  price     Decimal  @db.Decimal(10, 2) @default(0)
  isFullSet Boolean  @default(false)
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlayerCustomization {
  id        String   @id @default(cuid())
  name      String
  number    Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model menuitem {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  type        String    @default("link")
  linkUrl     String?
  pageContent String?   @db.LongText
  imageUrl    String?
  subtitle    String?
  parentId    String?
  parent      menuitem? @relation("MenuChildren", fields: [parentId], references: [id])
  children    menuitem[] @relation("MenuChildren")
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  isExternal  Boolean   @default(false)
  icon        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model footermenuitem {
  id          String   @id @default(cuid())
  block       Int
  title       String
  slug        String   @unique
  type        String   @default("page")
  linkUrl     String?
  pageContent String?  @db.LongText
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  isExternal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([block, order])
}

model footercontacts {
  id           String   @id @default("main")
  title        String   @default("Контакты")
  email        String   @default("info@dynamo-brest.by")
  addressLabel String   @default("Адрес офиса в Бресте")
  address      String   @default("г. Брест, ул. Гоголя, 9")
  updatedAt    DateTime @updatedAt
}